{
  "name": "shirabe",
  "version": "0.1.0",
  "description": "Official thin SDK for the Shirabe Japan-specific AI-native API platform — composite enrich (address, name, corporate number, calendar) in one call. Zero runtime dependencies.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "shirabe",
    "japan",
    "address-normalization",
    "rokuyo",
    "japanese-calendar",
    "corporate-number",
    "enrich",
    "ai",
    "llm",
    "agent"
  ],
  "license": "MIT",
  "author": "Techwell Inc. (https://shirabe.dev)",
  "homepage": "https://shirabe.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/techwell-inc-jp/shirabe-sdk"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
